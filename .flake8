[flake8]
exclude = .git,venv,.venv,__pycache__,*.pyc,*.egg-info,.eggs,build,dist,frontend,logs
max-line-length = 120
# Critical-only set: E9 = syntax errors, F63 = invalid format strings,
# F7 = break/continue outside loop, F82 = undefined name.
# Catches AI-generated breakage without churning on style nits.
select = E9,F63,F7,F82
